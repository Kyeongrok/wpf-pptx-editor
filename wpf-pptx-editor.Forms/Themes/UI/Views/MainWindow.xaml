<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:wpf_pptx_editor.Forms.Controls"
    xmlns:converters="clr-namespace:wpf_pptx_editor.Forms.Converters"
    xmlns:support="clr-namespace:wpf_pptx_editor.Support.UI.Units;assembly=wpf_pptx_editor.Support"
    xmlns:views="clr-namespace:wpf_pptx_editor.Forms.UI.Views">

    <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    <converters:ActiveToolConverter x:Key="ActiveToolConverter" />

    <!--  공통 툴바 버튼 스타일  -->
    <Style x:Key="ToolBtn" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#CCCCCC" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#3C3C3C" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#505050" />
            </Trigger>
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource ActiveToolConverter}">
                        <Binding Path="Editor.CurrentTool" />
                        <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Background" Value="#0078D4" />
                <Setter Property="Foreground" Value="White" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--  속성 라벨 스타일  -->
    <Style x:Key="PropLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#888" />
        <Setter Property="Margin" Value="0,8,0,3" />
    </Style>

    <!--  속성 입력 스타일  -->
    <Style x:Key="PropInput" TargetType="TextBox">
        <Setter Property="Background" Value="#3C3C3C" />
        <Setter Property="BorderBrush" Value="#555" />
        <Setter Property="Foreground" Value="#EEE" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style BasedOn="{StaticResource {x:Type support:wpf_pptx_editorWindow}}" TargetType="{x:Type views:MainWindow}">
        <Setter Property="Title" Value="{Binding WindowTitle}" />
        <Setter Property="Width" Value="1280" />
        <Setter Property="Height" Value="800" />
        <Setter Property="MinWidth" Value="900" />
        <Setter Property="MinHeight" Value="600" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:MainWindow}">
                    <Border
                        Background="#1E1E1E"
                        BorderBrush="#3C3C3C"
                        BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="44" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="24" />
                            </Grid.RowDefinitions>

                            <!--  타이틀 바  -->
                            <Grid Grid.Row="0" Background="#2D2D2D">
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#CCCCCC"
                                    Text="{TemplateBinding Title}" />
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button
                                        x:Name="PART_MinimizeButton"
                                        Width="46"
                                        Height="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Content="─"
                                        Cursor="Hand"
                                        FontSize="14"
                                        Foreground="#CCCCCC"
                                        WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3C3C3C" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button
                                        x:Name="PART_MaximizeButton"
                                        Width="46"
                                        Height="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Content="⬜"
                                        Cursor="Hand"
                                        FontSize="11"
                                        Foreground="#CCCCCC"
                                        WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3C3C3C" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button
                                        x:Name="PART_CloseButton"
                                        Width="46"
                                        Height="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Content="✕"
                                        Cursor="Hand"
                                        FontSize="14"
                                        Foreground="#CCCCCC"
                                        WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#C42B1C" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!--  툴바  -->
                            <Border
                                Grid.Row="1"
                                Background="#252526"
                                BorderBrush="#3C3C3C"
                                BorderThickness="0,1,0,1">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <StackPanel
                                        Margin="4,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                        <Button
                                            Command="{Binding NewFileCommand}"
                                            Content="📄 새 파일"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding OpenFileCommand}"
                                            Content="📂 열기"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding SaveCommand}"
                                            Content="💾 저장"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding SaveAsCommand}"
                                            Content="다른 이름"
                                            Style="{StaticResource ToolBtn}" />
                                        <Rectangle
                                            Width="1"
                                            Margin="4,8"
                                            Fill="#3C3C3C" />
                                        <Button
                                            Command="{Binding Editor.SelectToolCommand}"
                                            CommandParameter="Select"
                                            Content="↖ 선택"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding Editor.SelectToolCommand}"
                                            CommandParameter="Rectangle"
                                            Content="▭ 사각형"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding Editor.SelectToolCommand}"
                                            CommandParameter="RoundedRect"
                                            Content="▢ 둥근사각"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding Editor.SelectToolCommand}"
                                            CommandParameter="Ellipse"
                                            Content="○ 원"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding Editor.SelectToolCommand}"
                                            CommandParameter="Arrow"
                                            Content="╱ 선"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding Editor.SelectToolCommand}"
                                            CommandParameter="TextBox"
                                            Content="T 텍스트"
                                            Style="{StaticResource ToolBtn}" />
                                        <Button
                                            Command="{Binding Editor.DeleteSelectedCommand}"
                                            Content="🗑 삭제"
                                            Style="{StaticResource ToolBtn}" />
                                        <Rectangle
                                            Width="1"
                                            Margin="4,8"
                                            Fill="#3C3C3C" />
                                        <Button
                                            Command="{Binding AddSlideCommand}"
                                            Content="＋ 슬라이드"
                                            Style="{StaticResource ToolBtn}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!--  메인 영역  -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition
                                        Width="210"
                                        MinWidth="140"
                                        MaxWidth="380" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition
                                        Width="195"
                                        MinWidth="150"
                                        MaxWidth="300" />
                                </Grid.ColumnDefinitions>

                                <!--  슬라이드 목록  -->
                                <Grid Grid.Column="0" Background="#F7F7F7">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="36" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border
                                        Grid.Row="0"
                                        Padding="10,0"
                                        Background="#EBEBEB"
                                        BorderBrush="#D0D0D0"
                                        BorderThickness="0,0,0,1">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="#2D2D2D"
                                            Text="슬라이드" />
                                    </Border>
                                    <ListBox
                                        Grid.Row="1"
                                        Padding="0,4"
                                        Background="#F7F7F7"
                                        BorderThickness="0"
                                        ItemsSource="{Binding Slides}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        SelectedItem="{Binding SelectedSlide}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Margin" Value="6,3" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border
                                                                x:Name="Bd"
                                                                Background="White"
                                                                BorderBrush="#E0E0E0"
                                                                BorderThickness="1"
                                                                CornerRadius="2">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#0078D4" />
                                                                    <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="60">
                                                    <Image
                                                        RenderOptions.BitmapScalingMode="HighQuality"
                                                        Source="{Binding Thumbnail}"
                                                        Stretch="Uniform" />
                                                    <Border
                                                        Padding="3,1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="White"
                                                        Opacity="0.9">
                                                        <TextBlock
                                                            FontSize="10"
                                                            FontWeight="Bold"
                                                            Foreground="#444"
                                                            Text="{Binding SlideNumber}" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>

                                <!--  스플리터  -->
                                <GridSplitter
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Background="#BBBBBB"
                                    Cursor="SizeWE" />

                                <!--  편집 캔버스  -->
                                <Grid Grid.Column="2">
                                    <controls:SlideEditorControl x:Name="PART_SlideEditor" DataContext="{Binding Editor}" />
                                    <Border Background="#A0000000" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="15"
                                                Foreground="White"
                                                Text="로딩 중..." />
                                            <ProgressBar
                                                Width="180"
                                                Height="4"
                                                Margin="0,12,0,0"
                                                IsIndeterminate="True" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!--  스플리터  -->
                                <GridSplitter
                                    Grid.Column="3"
                                    HorizontalAlignment="Stretch"
                                    Background="#BBBBBB"
                                    Cursor="SizeWE" />

                                <!--  속성 패널  -->
                                <Border Grid.Column="4" Background="#2D2D2D">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="10" DataContext="{Binding Editor}">
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="#CCCCCC"
                                                Text="속성" />

                                            <TextBlock Style="{StaticResource PropLabel}" Text="현재 도구" />
                                            <Border
                                                Padding="8,5"
                                                Background="#3C3C3C"
                                                CornerRadius="4">
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="#CCCCCC"
                                                    Text="{Binding CurrentTool}" />
                                            </Border>

                                            <TextBlock Style="{StaticResource PropLabel}" Text="텍스트" />
                                            <TextBox Style="{StaticResource PropInput}" Text="{Binding ShapeText, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Style="{StaticResource PropLabel}" Text="폰트 크기 (pt)" />
                                            <TextBox Style="{StaticResource PropInput}" Text="{Binding FontSizePt, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Style="{StaticResource PropLabel}" Text="채우기 색상 (Hex)" />
                                            <TextBox
                                                x:Name="FillHexBox"
                                                Style="{StaticResource PropInput}"
                                                Text="{Binding FillColorHex, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Style="{StaticResource PropLabel}" Text="테두리 색상 (Hex)" />
                                            <TextBox Style="{StaticResource PropInput}" Text="{Binding StrokeColorHex, UpdateSourceTrigger=PropertyChanged}" />

                                            <TextBlock Style="{StaticResource PropLabel}" Text="테두리 두께 (pt)" />
                                            <TextBox Style="{StaticResource PropInput}" Text="{Binding StrokeWidthPt, UpdateSourceTrigger=PropertyChanged}" />

                                            <Separator Margin="0,12" Background="#3C3C3C" />

                                            <TextBlock Style="{StaticResource PropLabel}" Text="자주 쓰는 색상" />
                                            <UniformGrid Margin="0,4,0,0" Columns="6">
                                                <Button
                                                    x:Name="PART_Color1"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#4472C4"
                                                    BorderThickness="0"
                                                    ToolTip="#4472C4" />
                                                <Button
                                                    x:Name="PART_Color2"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#ED7D31"
                                                    BorderThickness="0"
                                                    ToolTip="#ED7D31" />
                                                <Button
                                                    x:Name="PART_Color3"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#A9D18E"
                                                    BorderThickness="0"
                                                    ToolTip="#A9D18E" />
                                                <Button
                                                    x:Name="PART_Color4"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#FFC000"
                                                    BorderThickness="0"
                                                    ToolTip="#FFC000" />
                                                <Button
                                                    x:Name="PART_Color5"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#5B9BD5"
                                                    BorderThickness="0"
                                                    ToolTip="#5B9BD5" />
                                                <Button
                                                    x:Name="PART_Color6"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#70AD47"
                                                    BorderThickness="0"
                                                    ToolTip="#70AD47" />
                                                <Button
                                                    x:Name="PART_Color7"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#FF0000"
                                                    BorderThickness="0"
                                                    ToolTip="#FF0000" />
                                                <Button
                                                    x:Name="PART_Color8"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#F5A0A0"
                                                    BorderThickness="0"
                                                    ToolTip="#F5A0A0" />
                                                <Button
                                                    x:Name="PART_Color9"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#FFFFFF"
                                                    BorderBrush="#888"
                                                    BorderThickness="1"
                                                    ToolTip="#FFFFFF" />
                                                <Button
                                                    x:Name="PART_Color10"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#000000"
                                                    BorderThickness="0"
                                                    ToolTip="#000000" />
                                                <Button
                                                    x:Name="PART_Color11"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="#808080"
                                                    BorderThickness="0"
                                                    ToolTip="#808080" />
                                                <Button
                                                    x:Name="PART_Color12"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="2"
                                                    Background="Transparent"
                                                    BorderBrush="#888"
                                                    BorderThickness="1"
                                                    ToolTip="투명" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>

                            <!--  상태 바  -->
                            <Border
                                Grid.Row="3"
                                Padding="8,0"
                                Background="#007ACC">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="White"
                                    Text="{Binding StatusMessage}" />
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
